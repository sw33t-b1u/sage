# Required
PROJECT_ID=your-project-id
SPANNER_INSTANCE=your-spanner-instance
SPANNER_DB=your-spanner-database
GCS_BUCKET=your-landing-bucket
# Optional — only required for OpenCTI ingestion mode.
# Not needed when running ETL with --input (local bundle) or for sage serve-api.
OPENCTI_URL=https://your-opencti-instance
OPENCTI_TOKEN=your-opencti-token

# Optional
# Local dev: input/pir.json (place BEACON output here)
# Container: /config/pir.json
PIR_FILE_PATH=input/pir.json
TLP_MAX_LEVEL=amber
ACTIVITY_WINDOW_DAYS=90

# Local emulator — Spanner client auto-connects when set (cmd/setup_emulator.py).
# SPANNER_EMULATOR_HOST=localhost:9010

# Analysis API bind port — Cloud Run injects this automatically; override locally
# if 8080 is taken. Consumed by cmd/analysis_api.py.
# PORT=8080

# Slack — ETL completion alerts with choke point summary
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/xxx/yyy/zzz

# GitHub Enterprise — choke point report Issues and IR templates
# GHE_TOKEN=your-personal-access-token
# GHE_REPO=owner/repo
# GHE_API_BASE=https://api.github.com  # override for self-hosted GHE

# MITRE Caldera — red team adversary profile sync
# CALDERA_URL=http://caldera.internal:8888
# CALDERA_API_KEY=your-caldera-api-key

# Analysis API — used by create_ir_template.py
# SAGE_API_URL=http://localhost:8080

# Analysis API authentication — Bearer token required for all endpoints.
# Omit to disable auth (NOT recommended for non-IAP deployments).
# SAGE_API_AUTH_TOKEN=your-secret-token

# Storage backend: "local" (default) or "gcs"
# SAGE_STORAGE=local
# SAGE_STORAGE_BASE_DIR=output
# SAGE_GCS_BUCKET=your-gcs-bucket
# SAGE_GCS_PREFIX=

# SAGE-specific activity window override (falls back to ACTIVITY_WINDOW_DAYS)
# SAGE_ACTIVITY_WINDOW_DAYS=90

# Suppress Spanner client built-in metrics export to Cloud Monitoring.
# Without this, a harmless 400 error is logged when instance_id cannot be resolved.
OTEL_SDK_DISABLED=true
