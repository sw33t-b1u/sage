# Required
GCP_PROJECT_ID=your-project-id
SPANNER_INSTANCE_ID=your-spanner-instance
SPANNER_DATABASE_ID=your-spanner-database
GCS_LANDING_BUCKET=your-landing-bucket
OPENCTI_URL=https://your-opencti-instance
OPENCTI_TOKEN=your-opencti-token

# Optional
# Local dev: PIR_FILE_PATH=tests/fixtures/sample_pir.json
# Container: PIR_FILE_PATH=/config/pir.json
PIR_FILE_PATH=/config/pir.json
TLP_MAX_LEVEL=amber
ACTIVITY_WINDOW_DAYS=90
