# === Backend selection (SAGE 4.0.0) ===
# "sqlite" (default) — SQLite file synced via the storage backend; no Spanner needed.
# "spanner" — Cloud Spanner (see the Spanner section below for the extra required vars).
SAGE_DB=sqlite

# === Required ===
GCP_PROJECT_ID=your-project-id

# === Storage backend ===
# "local" (default) — files under SAGE_STORAGE_BASE_DIR
# "gcs" — SQLite db + STIX bundles in a GCS bucket (cloud deployments).
#   sage-etl reads <bucket>/<prefix>/stix/ and publishes <bucket>/<prefix>/db/sage.db;
#   sage-api opens that same file read-only. Match TRACE's bucket/prefix so SAGE
#   consumes TRACE output (TRACE_STORAGE_BUCKET / TRACE_STORAGE_PREFIX).
SAGE_STORAGE=local
SAGE_STORAGE_BASE_DIR=output
# SAGE_STORAGE_BUCKET=your-gcs-bucket
# SAGE_STORAGE_PREFIX=trace/

# === PIR / filtering ===
# Local dev: input/pir.json (place BEACON output here)
# Container: /config/pir.json
PIR_FILE_PATH=input/pir.json
TLP_MAX_LEVEL=amber
ACTIVITY_WINDOW_DAYS=90
# SAGE-specific activity window override (falls back to ACTIVITY_WINDOW_DAYS)
# SAGE_ACTIVITY_WINDOW_DAYS=90

# === Analysis API ===
# Bind port — Cloud Run injects this automatically; override locally if 8080
# is taken. Consumed by cli/analysis_api.py.
# PORT=8080
# Authentication — Bearer token required for all endpoints.
# Omit to disable auth (NOT recommended for non-IAP deployments).
# SAGE_API_AUTH_TOKEN=your-secret-token
# Used by create_ir_template.py to reach the API.
# SAGE_API_URL=http://localhost:8080

# === OpenCTI ingestion (optional) ===
# Only required for OpenCTI ingestion mode. Not needed when running ETL with
# --input (local bundle), reading STIX bundles from GCS, or for sage serve-api.
# OPENCTI_URL=https://your-opencti-instance
# OPENCTI_TOKEN=your-opencti-token

# === Spanner backend (only when SAGE_DB=spanner) ===
# These four are required when SAGE_DB=spanner; ignored on the SQLite backend.
# SPANNER_INSTANCE=your-spanner-instance
# SPANNER_DB=your-spanner-database
# SAGE_ETL_INPUT_BUCKET=your-landing-bucket
# Local emulator — Spanner client auto-connects when set (cli/setup_emulator.py).
# SPANNER_EMULATOR_HOST=localhost:9010
# Suppress the Spanner client's built-in metrics export to Cloud Monitoring
# (harmless 400 logged when instance_id cannot be resolved). Spanner-only.
# OTEL_SDK_DISABLED=true

# === Slack — ETL completion alerts with choke point summary ===
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/xxx/yyy/zzz

# === GitHub Enterprise — choke point report Issues and IR templates ===
# GHE_TOKEN=your-personal-access-token
# GHE_REPO=owner/repo
# GHE_API_BASE=https://api.github.com  # override for self-hosted GHE

# === MITRE Caldera — red team adversary profile sync ===
# CALDERA_URL=http://caldera.internal:8888
# CALDERA_API_KEY=your-caldera-api-key
