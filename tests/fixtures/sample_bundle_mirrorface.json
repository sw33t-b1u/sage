  "objects": [
    {
      "type": "intrusion-set",
      "id": "intrusion-set--eac3257c-e7bc-44fe-aa65-9d4fa9f1a6a3",
      "spec_version": "2.1",
      "name": "MirrorFace",
      "aliases": [
        "Earth Kasha",
        "APT10 successor"
      ],
      "description": "中国に帰属するAPTグループ。日本の政府機関・防衛関連企業・メディアを標的とした持続的スパイ活動を展開。LODEINFOマルウェアを主要ツールとして使用。2024〜2025年にかけてVPN機器の脆弱性を悪用した侵入が確認されている。",
      "primary_motivation": "espionage",
      "secondary_motivations": [
        "organizational-gain"
      ],
      "sophistication": "advanced",
      "labels": [
        "apt",
        "targets-japan",
        "espionage"
      ],
      "first_seen": "2019-01-01T00:00:00Z",
      "last_seen": "2025-07-01T00:00:00Z",
      "created": "2022-01-01T00:00:00Z",
      "modified": "2025-07-01T00:00:00Z"
    },
    {
      "type": "malware",
      "id": "malware--397b9276-8552-4f7b-b03b-76c0116c1839",
      "spec_version": "2.1",
      "name": "LODEINFO",
      "description": "MirrorFaceが独自開発したバックドア型マルウェア。shellcodeローダーとして機能し、ファイル操作・コマンド実行・スクリーンショット取得・キーロギングが可能。正規ソフトウェアのサイドローディングにより検出を回避する。",
      "malware_types": [
        "backdoor",
        "keylogger"
      ],
      "is_family": true,
      "capabilities": [
        "backdoor",
        "exfiltration",
        "keylogging",
        "screen-capture"
      ],
      "created": "2020-01-01T00:00:00Z",
      "modified": "2025-06-01T00:00:00Z"
    },
    {
      "type": "attack-pattern",
      "id": "attack-pattern--9eb86d72-574e-4f49-aba2-f0bc4d45d3cd",
      "spec_version": "2.1",
      "name": "Exploit Public-Facing Application",
      "description": "公開VPN機器・Webサーバー等の既知脆弱性を悪用して初期侵入を実現する。MirrorFaceはArray Networks・Fortinet・Cisco等のVPN製品の脆弱性を積極的に悪用している。",
      "x_mitre_platforms": [
        "Linux",
        "Windows",
        "Network"
      ],
      "kill_chain_phases": [
