    {
      "type": "attack-pattern",
      "id": "attack-pattern--96aed346-b03a-4ea4-8e3c-acccecbfbb9a",
      "spec_version": "2.1",
      "name": "Phishing: Spearphishing Attachment",
      "description": "日本語の政策文書・選挙関連資料等を装った悪性Wordファイルを添付したスピアフィッシングメールを送付。マクロまたはテンプレートインジェクションによりLODEINFOをドロップする。",
      "x_mitre_platforms": [
        "Windows",
        "macOS",
        "Linux"
